<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Setting parallel="tests" allows all three browsers to execute simultaneously. -->
<suite name="AllRecipes Full Cross-Browser Suite" parallel="tests" thread-count="3" verbose="2">

    <!-- Attaches your dynamic, multi-threaded reporting mechanism -->
    <listeners>
        <listener class-name="utilities.TestListener"/>
    </listeners>

    <!-- Execution Block 1: Chrome Execution Path -->
    <test name="Regression Execution - Chrome Browser">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.HomeTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.NewsletterTest"/>
            <class name="tests.MyRecipesTest"/>
            <class name="tests.RecipeDetailTest"/>
            <class name="tests.SweepstakesTest"/>
        </classes>
    </test>

    <!-- Execution Block 2: Firefox Execution Path -->
    <test name="Regression Execution - Firefox Browser">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.HomeTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.NewsletterTest"/>
            <class name="tests.MyRecipesTest"/>
            <class name="tests.RecipeDetailTest"/>
            <class name="tests.SweepstakesTest"/>
        </classes>
    </test>

    <!-- Execution Block 3: Edge Execution Path -->
    <test name="Regression Execution - Edge Browser">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.HomeTest"/>
            <class name="tests.SearchTest"/>
            <class name="tests.NewsletterTest"/>
            <class name="tests.MyRecipesTest"/>
            <class name="tests.RecipeDetailTest"/>
            <class name="tests.SweepstakesTest"/>
        </classes>
    </test>

</suite>